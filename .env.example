# Copie para .env na raiz do projeto e altere a senha.
# docker compose -f docker-compose.vps.yml usa esta variável.
POSTGRES_PASSWORD=altere_para_uma_senha_forte

# Render (ou outro host): no painel do Web Service, adicione a variável
# DATABASE_URL com a URL interna do Postgres que o Render mostra (aba do banco).
# Não commite senhas nem URLs reais no Git.
# DATABASE_SSL=true   # opcional: força SSL (auto-detecta para hosts remotos)
# DATABASE_SSL=false  # opcional: desliga SSL (ex.: tunel local para um DB remoto)

# Vite (npm run dev / preview): para onde o proxy /api aponta.
# Na maquina (API em localhost:3001): deixe em branco ou use http://127.0.0.1:3001
# No container "dev" do docker-compose (ja definido no compose): http://api:3001
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# URL publica do Web Service da API (static site no Render + API em outro servico).
# Sem barra no final. Ex.: https://comprafacil-api1.onrender.com
# No painel do Static Site -> Environment, adicione esta variavel e faça redeploy (Clear build cache).
# Em dev local com proxy, deixe em branco.
# VITE_API_BASE_URL=

# true = após login, carrega 150 produtos + ~1500 vendas de demonstração (sem API para dados).
# Login ainda usa a API. O repositório inclui .env.production com true para o build ir populado.
# Em produção só com dados reais do banco: no painel do host defina VITE_DEMO_DATA=false e redeploy.
# VITE_DEMO_DATA=true
#
# Alternativa sem variavel: no Static Site -> Redirects/Rewrites, adicione:
#   Action: Rewrite | Source: /api/* | Destination: https://SUA-API.onrender.com/api/*
# (troque pela URL real do Web Service da API). Depois nao precisa VITE_API_BASE_URL no build.
