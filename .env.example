# Copie para .env na raiz do projeto e altere a senha.
# docker compose -f docker-compose.vps.yml usa esta variável.
POSTGRES_PASSWORD=altere_para_uma_senha_forte

# Vite (npm run dev / preview): para onde o proxy /api aponta.
# Na maquina (API em localhost:3001): deixe em branco ou use http://127.0.0.1:3001
# No container "dev" do docker-compose (ja definido no compose): http://api:3001
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
